---
import Base from '../layouts/Base.astro';
import { ModworksLogo } from '../components/ModworksLogo';
---

<Base>
  <main class='min-h-dvh flex flex-col items-center justify-center px-6'>
    <div class='flex flex-col items-center gap-10 max-w-lg text-center'>
      <div class='logo-container'>
        <ModworksLogo client:load width={180} />
      </div>

      <div class='copy flex flex-col items-center gap-3'>
        <p class='text-[17px] tracking-[-0.01em] text-bone/80 font-medium'>
          Life's better without handoffs.
        </p>
        <p class='text-[13px] tracking-[0.02em] text-bone/40 font-light'>
          Design and engineering at speed.
        </p>
      </div>
    </div>

    <!-- Floating dock -->
    <nav
      class='dock fixed bottom-8 left-1/2 -translate-x-1/2 flex items-center gap-0 bg-[#0a0a0a] rounded-full px-1 py-1 border border-white/[0.08] shadow-[0_4px_24px_rgba(0,0,0,0.5)]'
    >
      <a
        href='mailto:luke@modworks.design'
        class='dock-icon'
        data-tooltip='Send an email'
      >
        <!-- Lucide: mail -->
        <svg
          class='dock-svg'
          viewBox='0 0 24 24'
          fill='none'
          stroke='currentColor'
          stroke-width='2'
          stroke-linecap='round'
          stroke-linejoin='round'
        >
          <rect width='20' height='16' x='2' y='4' rx='2'></rect>
          <path d='m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7'></path>
        </svg>
      </a>
      <a
        href='https://www.linkedin.com/in/luke-moderwell/'
        target='_blank'
        rel='noopener'
        class='dock-icon'
        data-tooltip='Connect on LinkedIn'
      >
        <!-- Lucide: linkedin -->
        <svg
          class='dock-svg'
          viewBox='0 0 24 24'
          fill='none'
          stroke='currentColor'
          stroke-width='2'
          stroke-linecap='round'
          stroke-linejoin='round'
        >
          <path
            d='M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z'
          ></path>
          <rect width='4' height='12' x='2' y='9'></rect>
          <circle cx='4' cy='4' r='2'></circle>
        </svg>
      </a>
      <a
        href='https://github.com/lukemoderwell'
        target='_blank'
        rel='noopener'
        class='dock-icon'
        data-tooltip='Browse on GitHub'
      >
        <!-- Lucide: github -->
        <svg
          class='dock-svg'
          viewBox='0 0 24 24'
          fill='none'
          stroke='currentColor'
          stroke-width='2'
          stroke-linecap='round'
          stroke-linejoin='round'
        >
          <path
            d='M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C5 3 4 3 4 3c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9.5c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4'
          ></path>
          <path d='M9 18c-4.51 2-5-2-7-2'></path>
        </svg>
      </a>
      <div class='dock-divider'></div>
      <a href='/deck' class='dock-icon' data-tooltip='View capabilities'>
        <!-- Lucide: file-text -->
        <svg
          class='dock-svg'
          viewBox='0 0 24 24'
          fill='none'
          stroke='currentColor'
          stroke-width='2'
          stroke-linecap='round'
          stroke-linejoin='round'
        >
          <path d='M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z'
          ></path>
          <path d='M14 2v4a2 2 0 0 0 2 2h4'></path>
          <path d='M10 9H8'></path>
          <path d='M16 13H8'></path>
          <path d='M16 17H8'></path>
        </svg>
      </a>
    </nav>
  </main>
</Base>

<style>
  .copy,
  .dock {
    opacity: 0;
  }

  .copy {
    animation: fadeUp 0.8s ease-out 2.4s forwards;
  }

  .dock {
    animation: fadeUp 0.6s ease-out 3s forwards;
  }

  /* ── Dock icons ── */
  .dock-svg {
    width: 14px;
    height: 14px;
  }

  .dock-icon {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 9999px;
    color: rgba(255, 255, 255, 0.4);
    transition:
      color 0.15s ease,
      background-color 0.15s ease;
    cursor: pointer;
  }

  .dock-icon:hover {
    color: rgba(255, 255, 255, 0.95);
    background-color: rgba(255, 255, 255, 0.1);
  }

  /* ── Tooltip ── */
  .dock-icon::before {
    content: attr(data-tooltip);
    position: absolute;
    bottom: calc(100% + 10px);
    left: 50%;
    transform: translateX(-50%) translateY(4px);
    padding: 6px 12px;
    background: #0a0a0a;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.01em;
    color: rgba(255, 255, 255, 0.85);
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition:
      opacity 0.15s ease,
      transform 0.15s ease;
  }

  .dock-icon:hover::before {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  /* ── Divider ── */
  .dock-divider {
    width: 1px;
    height: 14px;
    background: rgba(255, 255, 255, 0.1);
    margin: 0 2px;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
